@inherits LayoutComponentBase
@inject NavigationManager Nav
@inject MfeNavigationService MfeNav
@inject IJSRuntime JS
@implements IAsyncDisposable

<div class="page" style="display:flex; flex-direction:column; height:100vh;">

    <div class="flex bg-gray-200 py-2 px-4 items-center" style="flex-shrink:0;">
        <NavMenu />
    </div>

    <div> Aquí va el MFE: </div>

    <div style="flex:1; overflow:hidden;">
        @if (_activeMfeUrl is not null)
        {
            <iframe src="@_activeMfeUrl"
                    style="width:100%; height:100%; border:none;"
                    title="MFE Content">
            </iframe>
        }
        else
        {
            <div class="px-4 py-8">
                <h2>Bienvenido</h2>
                <p>Selecciona un módulo del menú</p>
            </div>
        }
    </div>

</div>

@code {
    private string? _activeMfeUrl;
    private string? _activeMfeKey;
    private DotNetObjectReference<MainLayout>? _dotnetRef;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            // Registra el listener de mensajes del iframe
            _dotnetRef = DotNetObjectReference.Create(this);
            await JS.InvokeVoidAsync("listenMfeNavigation", _dotnetRef);

            Nav.LocationChanged += OnLocationChanged;
            ResolveActiveMfe(Nav.Uri);
            StateHasChanged();
        }
    }

    private void OnLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        ResolveActiveMfe(e.Location);
        StateHasChanged();
    }

    private void ResolveActiveMfe(string uri)
    {
        if (uri.Contains("/inicio"))
        {
            _activeMfeKey = "Inicio";
            _activeMfeUrl = MfeNav.GetMfe("Inicio").IframeUrl;
        }
        else if (uri.Contains("/portafolio"))
        {
            _activeMfeKey = "Portafolio";
            _activeMfeUrl = MfeNav.GetMfe("Portafolio").IframeUrl;
        }
        else if (uri.Contains("/siniestros"))
        {
            _activeMfeKey = "Siniestros";
            _activeMfeUrl = MfeNav.GetMfe("Siniestros").IframeUrl;
        }
        else
        {
            _activeMfeKey = null;
            _activeMfeUrl = null;
        }
    }

    // Este método lo llama el iframe via postMessage
    [JSInvokable]
    public void OnMfeNavigated(string mfePath)
    {
        if (_activeMfeKey is null) return;

        // Actualiza la URL del navegador sin recargar el iframe
        var shellPath = $"/{_activeMfeKey.ToLower()}/{mfePath}";
        Nav.NavigateTo(shellPath, forceLoad: false);
    }

    public async ValueTask DisposeAsync()
    {
        Nav.LocationChanged -= OnLocationChanged;
        _dotnetRef?.Dispose();
    }
}