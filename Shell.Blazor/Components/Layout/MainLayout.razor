@inherits LayoutComponentBase
@inject NavigationManager Nav
@inject MfeNavigationService MfeNav
@inject IJSRuntime JS
@implements IAsyncDisposable

<div class="page" style="display:flex; flex-direction:column; height:100vh;">

    <div class="flex bg-gray-200 py-2 px-4 items-center" style="flex-shrink:0;">
        <NavMenu />
    </div>

    <div style="flex:1; overflow:hidden;">
        @if (_activeMfeUrl is not null)
        {
            <iframe src="@_activeMfeUrl"
                    style="width:100%; height:100%; border:none;"
                    title="MFE Content">
            </iframe>
        }
        else
        {
            <div class="px-4 py-8">
                <h2>Bienvenido</h2>
                <p>Selecciona un módulo del menú</p>
            </div>
        }
    </div>

</div>

@code {
    private string? _activeMfeUrl;
    private string? _activeMfeKey;
    private DotNetObjectReference<MainLayout>? _dotnetRef;

    protected override void OnInitialized()
    {
        // Resuelve el MFE activo desde el primer render
        Nav.LocationChanged += OnLocationChanged;
        ResolveActiveMfe(Nav.Uri);
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            // Solo registra el listener de JS aquí
            _dotnetRef = DotNetObjectReference.Create(this);
            await JS.InvokeVoidAsync("listenMfeNavigation", _dotnetRef);
        }
    }

    private void OnLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        ResolveActiveMfe(e.Location);
        StateHasChanged();
    }

    private void ResolveActiveMfe(string uri)
    {
        // Extraer la ruta relativa
        // uri puede ser: http://localhost/inicio/security
        var path = new Uri(uri).AbsolutePath;

        if (path.StartsWith("/inicio"))
        {
            _activeMfeKey = "Inicio";
            // Extrae la subruta: /inicio/security → security
            var subroute = path.Substring("/inicio".Length).TrimStart('/');
            var baseUrl = MfeNav.GetMfe("Inicio").IframeUrl;
            _activeMfeUrl = string.IsNullOrEmpty(subroute)
                ? baseUrl
                : $"{baseUrl}/{subroute}";
        }
        else if (path.StartsWith("/portafolio"))
        {
            _activeMfeKey = "Portafolio";
            var subroute = path.Substring("/portafolio".Length).TrimStart('/');
            var baseUrl = MfeNav.GetMfe("Portafolio").IframeUrl;
            _activeMfeUrl = string.IsNullOrEmpty(subroute)
                ? baseUrl
                : $"{baseUrl}/{subroute}";
        }
        else if (path.StartsWith("/siniestros"))
        {
            _activeMfeKey = "Siniestros";
            var subroute = path.Substring("/siniestros".Length).TrimStart('/');
            var baseUrl = MfeNav.GetMfe("Siniestros").IframeUrl;
            _activeMfeUrl = string.IsNullOrEmpty(subroute)
                ? baseUrl
                : $"{baseUrl}/{subroute}";
        }
        else
        {
            _activeMfeKey = null;
            _activeMfeUrl = null;
        }
    }

    [JSInvokable]
    public void OnMfeNavigated(string mfePath)
    {
        if (_activeMfeKey is null) return;

        // mfePath llega como "security" o "dashboard"
        // lo limpiamos por si viene con slash al inicio
        var cleanPath = mfePath.TrimStart('/');

        // Si es la ruta raíz del MFE no agregamos subruta
        var shellPath = string.IsNullOrEmpty(cleanPath)
            ? $"/{_activeMfeKey.ToLower()}"
            : $"/{_activeMfeKey.ToLower()}/{cleanPath}";

        Nav.NavigateTo(shellPath, forceLoad: false);
    }

    public async ValueTask DisposeAsync()
    {
        Nav.LocationChanged -= OnLocationChanged;
        _dotnetRef?.Dispose();
    }
}