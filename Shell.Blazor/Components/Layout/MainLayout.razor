@inherits LayoutComponentBase
@inject NavigationManager Nav
@inject MfeNavigationService MfeNav

<div class="page" style="display:flex; flex-direction:column; height:100vh;">

    <div class="flex bg-gray-200 py-2 px-4 items-center" style="flex-shrink:0;">
        <NavMenu />
    </div>

    <div style="flex:1; overflow:hidden;">
        @if (_activeMfeUrl is not null)
        {
            <iframe src="@_activeMfeUrl"
                    style="width:100%; height:100%; border:none;"
                    title="MFE Content">
            </iframe>
        }
        else
        {
            <div class="px-4 py-8">
                <h2>Bienvenido</h2>
                <p>Selecciona un módulo del menú</p>
            </div>
        }
    </div>

</div>

@code {
    private string? _activeMfeUrl;

    protected override void OnInitialized()
    {
        Nav.LocationChanged += OnLocationChanged;
        ResolveActiveMfe(Nav.Uri);
    }

    private void OnLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        ResolveActiveMfe(e.Location);
        StateHasChanged();
    }

    private void ResolveActiveMfe(string uri)
    {
        if (uri.Contains("/inicio"))
            _activeMfeUrl = MfeNav.GetMfe("Inicio").IframeUrl;
        else if (uri.Contains("/portafolio"))
            _activeMfeUrl = MfeNav.GetMfe("Portafolio").IframeUrl;
        else if (uri.Contains("/siniestros"))
            _activeMfeUrl = MfeNav.GetMfe("Siniestros").IframeUrl;
        else
            _activeMfeUrl = null;
    }

    public void Dispose()
    {
        Nav.LocationChanged -= OnLocationChanged;
    }
}