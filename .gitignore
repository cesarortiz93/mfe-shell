## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ons.

# User-specific files
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates

# Build results
[Dd]ebug/
[Rr]elease/
x64/
x86/
bld/
[Bb]in/
[Oo]bj/
out/

# Build outputs
**/obj/
**/bin/

# .NET Core
project.lock.json
project.fragment.lock.json
artifacts/

# Visual Studio Code
.vscode/

# Visual Studio
.vs/

# Rider
.idea/

# Logs
*.log

# ASP.NET Scaffolding
ScaffoldingReadMe.txt

# Node (usado a veces en proyectos Blazor WebAssembly)
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Blazor WebAssembly build output
wwwroot/dist/
wwwroot/lib/

# Publish output
publish/
*.pubxml.user

# OS files
.DS_Store
Thumbs.db

# Test results
TestResults/

# Coverage
coverage/
*.coverage
*.coveragexml

# NuGet
*.nupkg
*.snupkg
packages/
.nuget/packages/
*.nuget.dgspec.json
project.assets.json
project.nuget.cache
*.nuget.cache

# Secrets
secrets.json
appsettings.Development.json

# Generated files
Generated/

# Env
.env

# Assembly info cache
*.AssemblyInfo.cs
*.AssemblyInfoInputs.cache

# NuGet restore cache
rpswa.dswa.cache.json